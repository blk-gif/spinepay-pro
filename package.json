{
  "name": "spinepay-pro",
  "version": "1.0.0",
  "description": "SpinePay Pro - Practice Management for Walden Bailey Chiropractic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test-speech": "powershell.exe -ExecutionPolicy Bypass -NonInteractive -File speech-server.ps1"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^9.4.3",
    "nodejs-whisper": "^0.2.9",
    "stripe": "^14.18.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.waldenbailey.spinepay-pro",
    "productName": "SpinePay Pro",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
